 "_klasser": {
  "omega": {
   "beskrivning": "Tematiska ω-verb. Ändelse på stammen, recessiv betoning. Futurum bildas med inskott av -σ- mellan stam och ändelse (λύ-σ-ω); infinitiv på -ειν (pres. λύ-ειν, fut. λύ-σ-ειν); imperativ -ε/-έτω/-ετε/-έτωσαν; imperfekt augment + sekundära ändelser.",
   "andelser": {
    "pres.ind.akt": {
     "1sg": "-ω",
     "2sg": "-εις",
     "3sg": "-ει",
     "1pl": "-ομεν",
     "2pl": "-ετε",
     "3pl": "-ουσι(ν)"
    },
    "fut.ind.akt": {
     "1sg": "-σω",
     "2sg": "-σεις",
     "3sg": "-σει",
     "1pl": "-σομεν",
     "2pl": "-σετε",
     "3pl": "-σουσι(ν)"
    },
    "pres.inf.akt": {
     "inf": "-ειν"
    },
    "pres.imp.akt": {
     "2sg": "-ε",
     "3sg": "-έτω",
     "2pl": "-ετε",
     "3pl": "-έτωσαν (koine; klass. -όντων)"
    },
    "impf.ind.akt": {
     "1sg": "-ον",
     "2sg": "-ες",
     "3sg": "-ε(ν)",
     "1pl": "-ομεν",
     "2pl": "-ετε",
     "3pl": "-ον",
     "augment": "ἐ- före konsonant; vokal förlängs (ἀ/ε→η, αι→ῃ, ευ→ηυ); sammansatta får inre augment"
    },
    "fut.inf.akt": {
     "inf": "-σειν"
    }
   }
  },
  "kontrakt_e": {
   "beskrivning": "Stam på -ε, kontraherar med ändelsen i presens; betoning på kontraktionsstavelsen (cirkumflex). I futurum upphäver -σ- kontraktionen och ε förlängs till η (φιλέ→φιλή-σω).",
   "andelser": {
    "pres.ind.akt": {
     "1sg": "-ῶ",
     "2sg": "-εῖς",
     "3sg": "-εῖ",
     "1pl": "-οῦμεν",
