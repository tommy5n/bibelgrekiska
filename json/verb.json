     "1sg": "-ουν",
     "2sg": "-εις",
     "3sg": "-ει",
     "1pl": "-οῦμεν",
     "2pl": "-εῖτε",
     "3pl": "-ουν",
     "not": "kontraherat (ε+ο→ου, ε+ε→ει); samma augmentregler"
    },
    "fut.inf.akt": {
     "inf": "-ήσειν"
    }
   },
   "kontraktionsregler": [
    "ε+ε=ει",
    "ε+ο=ου",
    "ε+lång vokal=lång vokal"
   ]
  },
