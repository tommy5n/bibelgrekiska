 "_futurumklasser": {
  "_om": "Klassificering av futurum aktiv/medium-stambildning efter verbrotens slut (Blomqvist § 165-166). Styr framtida grammatikreferens/spel.",
  "vokal": "Rot på vokal; vokalen förlängs framför σ (ᾱ→η utom efter ε/ι/ρ; -έω→-ήσω). Ex: ἀγαπάω→ἀγαπήσω, φιλέω→φιλήσω.",
  "diftong": "Rot på diftong/vokal+halvvokal; oförändrad framför σ. Ex: παιδεύω→παιδεύσω.",
  "sigma": "Rot på -σ; faller framför suffix-σ. Ex: ἀκούω→ἀκούσω, εἰμί→ἔσομαι.",
  "labial": "Rot på labial klusil (π/β/φ); + σ = ψ. Ex: γράφω→γράψω, λαμβάνω→λήμψομαι.",
  "velar": "Rot på velar klusil (κ/γ/χ); + σ = ξ. Ex: κηρύσσω→κηρύξω, ἄγω→ἄξω.",
  "dental": "Rot på dental klusil (τ/δ/θ); faller framför σ. -ίζω-verb får koine -ίσω. Ex: βαπτίζω→βαπτίσω, σῴζω→σώσω.",
  "kontraherat": "Futurum atticum: liquida/nasal-rot (λ/ρ/ν/μ) → kontraherat -ῶ (B § 166a). Berör inga nuvarande verb.",
  "suppletiv": "Futurum från annan rot (λέγω→ἐρῶ, ἐσθίω→φάγομαι). Ej upplagt än."
 }
