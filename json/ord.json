  "_falt": {
    "glosaGen": "Svensk genitiv (explicit dar -s-regeln inte racker, t.ex. Kristus -> Kristi)",
    "accenttyp": "oxyton | paroxyton | proparoxyton | properispomenon",
    "seminarium": "Kursseminarier dar ordet forekommer ([] = endast fran NT-frekvenslistan)",
    "kortlekar": "Fordefinierade urval: sem1, sem2, ovriga, oxytona, neutrum, feminina",
    "ntFrekvensOver60": "true om ordet forekommer >60 ggr i NT (annars seminarium 1-lasord)",
    "deklination": "1 (feminina pa -α/-η) eller 2 (-ος/-ον)"
  },
  "_kortlekar": {
    "sem1": "Seminarium 1 (lasovning)",
    "sem2": "Seminarium 2 (deklinationslektion)",
    "ovriga": "Hogfrekventa NT-ord (>60 ggr), ej i seminarielistorna",
    "oxytona": "Accent pa sista stavelsen -> cirkumflex i genitiv/dativ",
    "neutrum": "Andra deklinationens neutrala substantiv (-ον), seminarium 3",
    "feminina": "Forsta deklinationens feminina substantiv (-α/-η), seminarium 4"
  },
